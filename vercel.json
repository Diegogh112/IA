{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/upload", "dest": "api/index.py" },
    { "src": "/ask",    "dest": "api/index.py" },
    { "src": "/health", "dest": "api/index.py" },
    { "src": "/docs",   "dest": "api/index.py" },
    { "src": "/openapi.json", "dest": "api/index.py" },
    { "src": "/static/(.*)", "dest": "static/$1" },
    { "src": "/(.*)",   "dest": "static/index.html" }
  ]
}
